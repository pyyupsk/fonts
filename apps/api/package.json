{
  "name": "@fonts/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "CLOUDFLARE_API_TOKEN=$(cat ../../.cloudflare-token) wrangler dev --remote",
    "dev:local": "wrangler dev --persist-to ../../.wrangler-state",
    "deploy": "CLOUDFLARE_API_TOKEN=$(cat ../../.cloudflare-token) wrangler deploy"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.26"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260621.1",
    "@fonts/db": "workspace:*",
    "@fonts/tsconfig": "workspace:*",
    "typescript": "^6.0.3",
    "wrangler": "^4.103.0"
  }
}
