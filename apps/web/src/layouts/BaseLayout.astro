---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  footer?: boolean;
}

const { title, description, ogImage = "/og.png", footer = true } = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://cdn.fasu.dev" crossorigin />
    <link rel="canonical" href={canonicalUrl} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Fonts" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <slot name="head" />
  </head>
  <body>
    <main class="mx-auto max-w-7xl px-md py-lg pb-2xl">
      <slot />
    </main>
    {
      footer && (
        <footer class="mx-auto max-w-7xl px-md py-lg border-t border-ink-border flex flex-wrap items-center justify-between gap-sm text-label text-paper-muted">
          <span>Fonts by pyyupsk · open-license type catalog</span>
          <a
            class="underline transition-colors duration-fast ease-out-quart hover:text-accent"
            href="https://github.com/pyyupsk/fonts"
            target="_blank"
            rel="noopener noreferrer"
          >
            Source on GitHub ↗
          </a>
        </footer>
      )
    }
  </body>
</html>
