{
  "name": "@fonts/db",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    "./schema/licenses": "./src/schema/licenses.ts",
    "./schema/subsets": "./src/schema/subsets.ts",
    "./schema/families": "./src/schema/families.ts",
    "./schema/family-subsets": "./src/schema/family-subsets.ts",
    "./schema/variants": "./src/schema/variants.ts",
    "./schema/files": "./src/schema/files.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply fonts-db --local --persist-to ../../.wrangler-state",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@fonts/tsconfig": "workspace:*",
    "@types/node": "^26.0.0",
    "better-sqlite3": "^12.11.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "wrangler": "^4.103.0"
  }
}
