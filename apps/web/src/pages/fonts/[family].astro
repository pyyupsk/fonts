---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { FontSpecimenList } from "../../components/FontSpecimenList.tsx";
import { getAllFamilies, getAllFamilyDetails } from "../../lib/build-data";

export async function getStaticPaths() {
  const families = await getAllFamilies();
  const details = await getAllFamilyDetails(families);

  return families
    .filter((family) => details.has(family.id))
    .map((family) => ({
      params: { family: family.id },
      props: { detail: details.get(family.id)! },
    }));
}

const { detail } = Astro.props;
const apiBase = import.meta.env.API_BASE;
---

<BaseLayout title={`${detail.family.name} — Fonts`}>
  <a
    href="/"
    class="text-label text-paper-muted hover:text-accent transition-colors duration-fast ease-out-quart"
  >
    ← back
  </a>
  <h1
    class="font-display text-display font-normal leading-[0.95] tracking-[-0.02em] mt-sm mb-sm"
  >
    {detail.family.name}
  </h1>
  <p class="text-paper-muted mb-xs">
    {detail.family.designer} · {detail.family.category} · {
      detail.family.license
    }
  </p>
  <p class="text-label text-paper-muted mb-lg">
    Subsets: {detail.subsets.map((subset) => subset.name).join(", ")}
  </p>

  <FontSpecimenList
    client:load
    apiBase={apiBase}
    familyId={detail.family.id}
    variants={detail.variants}
  />

  <section class="mt-2xl">
    <h2 class="text-heading font-display font-normal mb-md">Download</h2>
    <div class="border-t border-ink-border">
      {
        detail.variants.map((variant) => (
          <div class="flex items-center justify-between gap-md py-sm border-b border-ink-border">
            <span class="text-label text-paper">
              {variant.weight} {variant.style}
            </span>
            <a
              class="text-label text-paper-muted hover:text-accent transition-colors duration-fast ease-out-quart"
              href={`${apiBase}/api/fonts/${detail.family.id}/${variant.id}.woff2`}
              download
            >
              Download .woff2 ↓
            </a>
          </div>
        ))
      }
    </div>
  </section>

  <section class="mt-2xl mb-2xl">
    <h2 class="text-heading font-display font-normal mb-md">Embed</h2>
    <pre
      class="overflow-x-auto rounded border border-ink-border bg-ink-raised p-md text-label font-sans text-paper-muted"><code>{`@font-face {
  font-family: "${detail.family.name}";
  src: url("${apiBase}/api/fonts/${detail.family.id}/${detail.variants[0]?.id}.woff2") format("woff2");
  font-weight: ${detail.variants[0]?.weight ?? 400};
  font-style: ${detail.variants[0]?.style ?? "normal"};
}`}</code></pre>
  </section>
</BaseLayout>
