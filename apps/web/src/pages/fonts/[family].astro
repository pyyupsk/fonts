---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { BackLink } from "../../components/nav/back-link";
import { EmbedSnippet } from "../../components/font/embed-snippet";
import { FontSpecimenList } from "../../components/font/font-specimen-list";
import { buildEmbedSnippet } from "../../lib/build-embed-snippet";
import { getAllFamilies, getAllFamilyDetails } from "../../lib/build-data";
import {
  previewFontFamilyName,
  variableFontFamilyName,
} from "../../lib/font-family-name";
import { highlightCss } from "../../lib/highlight-css";

export async function getStaticPaths() {
  const families = await getAllFamilies();
  const details = await getAllFamilyDetails();

  return families
    .filter((family) => details.has(family.id))
    .map((family) => ({
      params: { family: family.id },
      props: { detail: details.get(family.id)! },
    }));
}

const { detail } = Astro.props;

const description = `Download ${detail.family.name} by ${detail.family.designer} — ${detail.family.category}, ${detail.family.license} license. Self-hosted .woff2 with copy-paste @font-face embed.`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: detail.family.name,
  creator: detail.family.designer,
  license: detail.family.license,
  genre: detail.family.category,
};

const isVariableFamily =
  detail.family.wghtMin !== null &&
  detail.family.wghtMax !== null &&
  detail.family.wghtMin < detail.family.wghtMax;

const previewFontFaces = isVariableFamily
  ? [...new Set(detail.variants.map((variant) => variant.style))].map(
      (style) => {
        const variant = detail.variants.find((entry) => entry.style === style)!;
        return {
          fontFamily: variableFontFamilyName(detail.family.id, style),
          fileUrl: variant.fileUrl,
          style,
          fontWeight: `${detail.family.wghtMin} ${detail.family.wghtMax}`,
        };
      },
    )
  : detail.variants.map((variant) => ({
      fontFamily: previewFontFamilyName(detail.family.id, variant.id),
      fileUrl: variant.fileUrl,
      style: variant.style,
      fontWeight: variant.weight.toString(),
    }));

const previewFontFaceCss = previewFontFaces
  .map(
    (face) => `@font-face {
  font-family: "${face.fontFamily}";
  src: url("${face.fileUrl}") format("woff2");
  font-weight: ${face.fontWeight};
  font-style: ${face.style};
  font-display: block;
}`,
  )
  .join("\n");

const embedSnippets = await Promise.all(
  detail.variants.map(async (variant) => {
    const code = buildEmbedSnippet({
      familyName: detail.family.name,
      fileUrl: variant.fileUrl,
      weight: variant.weight,
      style: variant.style,
      wghtMin: detail.family.wghtMin,
      wghtMax: detail.family.wghtMax,
    });
    return {
      variantId: variant.id,
      code,
      highlightedHtml: await highlightCss(code),
    };
  }),
);
---

<BaseLayout title={`${detail.family.name} — Fonts`} description={description}>
  <Fragment slot="head">
    {
      previewFontFaces.map((face) => (
        <link
          rel="preload"
          as="font"
          type="font/woff2"
          href={face.fileUrl}
          crossorigin="anonymous"
        />
      ))
    }
    <style set:html={previewFontFaceCss}></style>
  </Fragment>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(jsonLd)}
  />
  <BackLink client:load />
  <h1
    class="font-display text-display font-normal leading-[0.95] tracking-[-0.02em] mt-sm mb-sm"
  >
    {detail.family.name}
  </h1>
  <p class="text-paper-muted mb-xs">
    {detail.family.designer} · {detail.family.category} · {
      detail.family.license
    }
  </p>
  <p class="text-label text-paper-muted mb-lg">
    Subsets: {detail.subsets.map((subset) => subset.name).join(", ")}
  </p>

  <FontSpecimenList
    client:load
    familyId={detail.family.id}
    variants={detail.variants}
    wghtMin={detail.family.wghtMin}
    wghtMax={detail.family.wghtMax}
  />

  <section class="mt-2xl mb-2xl">
    <h2 class="text-heading font-display font-normal mb-md">
      Download &amp; embed
    </h2>
    <div class="border-t border-ink-border">
      {
        detail.variants.map((variant) => {
          const snippet = embedSnippets.find(
            (entry) => entry.variantId === variant.id,
          )!;
          return (
            <div class="py-md border-b border-ink-border">
              <div class="flex items-center justify-between gap-md mb-sm">
                <span class="text-label text-paper-muted">
                  {detail.family.wghtMin !== null &&
                  detail.family.wghtMax !== null &&
                  detail.family.wghtMin < detail.family.wghtMax
                    ? `${detail.family.wghtMin}–${detail.family.wghtMax}`
                    : variant.weight}{" "}
                  {variant.style}
                </span>
                <a
                  class="text-label text-paper hover:text-accent transition-colors duration-fast ease-out-quart"
                  href={variant.fileUrl}
                  download
                >
                  Download .woff2 ↓
                </a>
              </div>
              <EmbedSnippet
                client:load
                code={snippet.code}
                highlightedHtml={snippet.highlightedHtml}
              />
            </div>
          );
        })
      }
    </div>
  </section>
</BaseLayout>
