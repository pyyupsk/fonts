---
import { hc } from "hono/client";
import { API_BASE, PUBLIC_API_BASE } from "astro:env/server";
import type { AppType } from "@fonts/api";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { BackLink } from "@/components/nav/back-link";
import { EmbedTabs } from "@/components/docs/embed-tabs";
import { CodeBlock } from "@/components/ui/code-block";
import { highlightCss, highlightJson, highlightText } from "@/lib/highlighter";
import { safe } from "@/lib/safe";

const description =
  "Self-host any font from the catalog via @font-face, or query the catalog programmatically via the REST API.";

const STATIC_FAMILY = "aguafina-script";
const VARIABLE_FAMILY = "inter";

const client = hc<AppType>(API_BASE).api.fonts;

const [[staticRes], [variableRes], [listRes]] = await Promise.all([
  safe(client[":family"].$get({ param: { family: STATIC_FAMILY } })),
  safe(client[":family"].$get({ param: { family: VARIABLE_FAMILY } })),
  safe(client.$get({ query: { search: VARIABLE_FAMILY } })),
]);

if (!staticRes?.ok || !variableRes?.ok || !listRes?.ok) {
  throw new Error(`Failed to fetch docs examples from ${API_BASE}`);
}

const [staticFamilyJson, variableFamilyJson, listJson] = await Promise.all([
  staticRes.json(),
  variableRes.json(),
  listRes.json(),
]);

const staticVariant = staticFamilyJson.variants[0];
const variableVariant = variableFamilyJson.variants.find(
  (variant: { style: string }) => variant.style === "normal",
);

const embedExample = `@font-face {
  font-family: "${staticFamilyJson.family.name}";
  src: url("${staticVariant.fileUrl}") format("woff2");
  font-weight: ${staticVariant.weight};
  font-style: ${staticVariant.style};
}`;

const variableEmbedExample = `@font-face {
  font-family: "${variableFamilyJson.family.name}";
  src: url("${variableVariant.fileUrl}") format("woff2");
  font-weight: ${variableFamilyJson.family.wghtMin} ${variableFamilyJson.family.wghtMax};
  font-style: ${variableVariant.style};
}`;

const [embedHtml, variableEmbedHtml] = await Promise.all([
  highlightCss(embedExample),
  highlightCss(variableEmbedExample),
]);

const endpoints = [
  {
    method: "GET",
    path: "/api/fonts",
    description: "List families, optionally filtered.",
    params: [
      [
        "category",
        "string",
        "e.g. sans-serif, serif, display, handwriting, monospace",
      ],
      ["license", "string", "ofl | apache | ufl"],
      ["search", "string", "match against family name"],
    ],
    response: JSON.stringify(listJson, null, 2),
  },
  {
    method: "GET",
    path: "/api/fonts/full",
    description:
      "All families with their variants and subsets in one call. Used by this site's build step — heaviest endpoint, prefer caching the result.",
    params: [],
    response: JSON.stringify(
      {
        families: [
          {
            family: variableFamilyJson.family,
            variants: [variableVariant],
            subsets: variableFamilyJson.subsets.slice(0, 2),
          },
        ],
      },
      null,
      2,
    ),
  },
  {
    method: "GET",
    path: "/api/fonts/:family",
    description:
      "Single family by id, with variants and subsets. 404 if unknown.",
    params: [["family", "string (path)", "family id, e.g. inter"]],
    response: JSON.stringify(staticFamilyJson, null, 2),
  },
];

const baseUrlHtml = await highlightText(PUBLIC_API_BASE);

const endpointHtml = await Promise.all(
  endpoints.map((endpoint) =>
    highlightJson(endpoint.response).then((html) => ({ ...endpoint, html })),
  ),
);
---

<BaseLayout title="Docs — Fonts" description={description}>
  <BackLink client:load />
  <h1
    class="font-display text-display font-normal leading-[0.95] tracking-[-0.02em] mt-sm mb-md"
  >
    Docs
  </h1>
  <p class="text-paper-muted mb-2xl max-w-prose">{description}</p>

  <section class="mb-2xl">
    <h2 class="text-heading font-display font-normal mb-md">Why this</h2>
    <p class="text-paper-muted mb-md max-w-prose">
      Not the biggest catalog (Google) or the slickest npm packaging
      (Fontsource) — built on taste. Real <code>@font-face</code> previews, not metadata
      tables. Per-variant <code>.woff2</code> served direct from the CDN with an immutable
      one-year cache, no tracking. A public REST API for the whole catalog. No npm
      step, no hostname swap, no sterile grid.
    </p>
  </section>

  <section class="mb-2xl">
    <h2 class="text-heading font-display font-normal mb-md">
      Self-hosting a font
    </h2>
    <p class="text-paper-muted mb-md max-w-prose">
      Every variant is served as a standalone <code>.woff2</code> file from our CDN.
      Copy the <code>@font-face</code> block from any family page, or use the pattern
      below — static weight on the left, variable range on the right.
    </p>
    <EmbedTabs
      client:load
      staticCode={embedExample}
      staticHtml={embedHtml}
      variableCode={variableEmbedExample}
      variableHtml={variableEmbedHtml}
    />
  </section>

  <section class="mb-2xl">
    <h2 class="text-heading font-display font-normal mb-md">REST API</h2>
    <p class="text-paper-muted mb-md max-w-prose">
      Public, no auth, CORS open. Base URL:
    </p>
    <div class="mb-lg">
      <CodeBlock
        client:load
        code={PUBLIC_API_BASE}
        highlightedHtml={baseUrlHtml}
      />
    </div>

    <div class="border-t border-ink-border">
      {
        endpointHtml.map((endpoint) => (
          <div class="py-lg border-b border-ink-border">
            <p class="text-label mb-2xs">
              <span class="text-accent">{endpoint.method}</span>{" "}
              <span class="text-paper">{endpoint.path}</span>
            </p>
            <p class="text-paper-muted mb-sm max-w-prose">
              {endpoint.description}
            </p>
            {endpoint.params.length > 0 && (
              <ul class="flex flex-col gap-2xs mb-sm text-label">
                {endpoint.params.map(([name, type, note]) => (
                  <li class="text-paper-muted">
                    <span class="text-paper">{name}</span>{" "}
                    <span class="text-paper-muted">({type})</span> — {note}
                  </li>
                ))}
              </ul>
            )}
            <CodeBlock
              client:load
              code={endpoint.response}
              highlightedHtml={endpoint.html}
            />
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>
