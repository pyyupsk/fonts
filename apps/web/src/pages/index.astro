---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { CatalogFilter } from "@/components/catalog/catalog-filter.tsx";
import type { CatalogEntry } from "@/components/catalog/catalog-filter.tsx";
import { getAllFamilies, getAllFamilyDetails } from "@/lib/build-data";

const families = await getAllFamilies();
const details = await getAllFamilyDetails();

const catalog: CatalogEntry[] = families.map((family) => {
  const detail = details.get(family.id);
  const variants = detail?.variants ?? [];
  const defaultVariant =
    variants.find(
      (variant) => variant.weight === 400 && variant.style === "normal",
    ) ?? variants[0];

  return {
    id: family.id,
    name: family.name,
    designer: family.designer,
    category: family.category,
    license: family.license,
    defaultFileUrl: defaultVariant?.fileUrl ?? "",
    weights: [...new Set(variants.map((variant) => variant.weight))],
    styles: [...new Set(variants.map((variant) => variant.style))],
    subsets: detail?.subsets.map((subset) => subset.name) ?? [],
  };
});
---

<BaseLayout
  title="Fonts — a self-hosted, open-license type catalog"
  description="Browse, compare, and download open-license fonts. Self-hosted webfonts with instant CDN delivery and copy-paste @font-face embeds."
>
  <header class="border-b border-ink-border pt-xl pb-lg mb-lg">
    <h1
      class="font-display text-display font-normal leading-[0.95] tracking-[-0.02em] text-balance"
    >
      Fonts <span class="text-heading text-paper-muted">by pyyupsk</span>
    </h1>
    <p class="max-w-[42ch] text-pretty text-paper-muted text-label mt-sm">
      A self-hosted, open-license type catalog. Browse, compare, and grab the
      file.
    </p>
  </header>
  <CatalogFilter client:load catalog={catalog} />
</BaseLayout>
