---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Something went wrong — Fonts"
  description="Something went wrong on our end. Try again in a moment."
>
  <div class="py-2xl">
    <h1
      class="font-display text-display font-normal leading-[0.95] tracking-[-0.02em] mb-sm"
    >
      500
    </h1>
    <p
      class="max-w-[42ch] text-pretty text-paper-muted text-[clamp(1rem,1.6vw,1.25rem)] mb-lg"
    >
      Something went wrong on our end. Try again in a moment.
    </p>
    <a
      href="/"
      class="inline-flex items-center min-h-11 px-sm -mx-sm text-label text-paper-muted hover:text-accent transition-colors duration-fast ease-out-quart"
    >
      ← Back to the catalog
    </a>
  </div>
</BaseLayout>
