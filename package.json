{
  "name": "fonts-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.14",
  "resolutions": {
    "vite": "7.3.5"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "prepare": "nit install",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "nit": {
    "hooks": {
      "pre-commit": {
        "stages": {
          "**/*.{ts,tsx,js,mjs,cjs,astro}": "bunx eslint {staged_files}",
          "**/*.{ts,tsx,js,mjs,cjs,jsx,astro,json,jsonc,css,md}": "bunx prettier --check {staged_files}"
        }
      }
    }
  },
  "devDependencies": {
    "@pyyupsk/nit": "^0.3.0",
    "astro-eslint-parser": "^2.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^2.0.0",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "turbo": "^2.9.18",
    "typescript-eslint": "^8.62.0"
  }
}
